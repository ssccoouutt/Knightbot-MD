const fs = require('fs');
const path = require('path');
const axios = require('axios');
const { downloadContentFromMessage } = require('@whiskeysockets/baileys');

async function bulkjoinCommand(sock, chatId, message, args) {
    const startTime = Date.now();
    const results = {
        total: 0,
        successful: 0,
        failed: 0,
        alreadyIn: 0,
        requestSent: 0,
        invalid: 0,
        details: []
    };

    try {
        // Check if user is owner/sudo
        const senderId = message.key.participant || message.key.remoteJid;
        const isOwnerOrSudo = await require('../lib/isOwner')(senderId, sock, chatId);
        
        if (!message.key.fromMe && !isOwnerOrSudo) {
            await sock.sendMessage(chatId, { 
                text: '❌ Only bot owner can use this command!' 
            }, { quoted: message });
            return;
        }

        // Check if replying to a document
        const quotedMessage = message.message?.extendedTextMessage?.contextInfo?.quotedMessage;
        if (!quotedMessage?.documentMessage) {
            await sock.sendMessage(chatId, { 
                text: '❌ Please reply to a .txt file containing group links!\n\nFormat: One group link per line\nExample:\nhttps://chat.whatsapp.com/ABC123\nhttps://chat.whatsapp.com/XYZ789' 
            }, { quoted: message });
            return;
        }

        // Send initial processing message
        await sock.sendMessage(chatId, { 
            text: '📥 *Downloading and processing file...*\n⏳ Please wait.' 
        });

        // Download the file
        const document = quotedMessage.documentMessage;
        const fileName = document.fileName || 'groups.txt';
        
        // Check if it's a text file
        if (!fileName.endsWith('.txt') && document.mimetype !== 'text/plain') {
            await sock.sendMessage(chatId, { 
                text: '❌ Please upload a .txt file!' 
            });
            return;
        }

        // Download file content
        const stream = await downloadContentFromMessage(document, 'document');
        const buffer = [];
        for await (const chunk of stream) {
            buffer.push(chunk);
        }
        
        const fileContent = Buffer.concat(buffer).toString('utf-8');
        const links = fileContent.split('\n')
            .map(line => line.trim())
            .filter(line => line.length > 0 && (line.includes('chat.whatsapp.com/') || line.match(/^[A-Za-z0-9_-]{20,}$/)));

        results.total = links.length;

        if (results.total === 0) {
            await sock.sendMessage(chatId, { 
                text: '❌ No valid WhatsApp group links found in the file!' 
            });
            return;
        }

        // Send start message
        await sock.sendMessage(chatId, { 
            text: `🔄 *Starting bulk join process*\n\n📊 Total links found: ${results.total}\n⏱️ Estimated time: ${results.total * 5} seconds\n\n✅ I'll update you after each join.` 
        });

        // Process each link
        for (let i = 0; i < links.length; i++) {
            const link = links[i];
            const linkNumber = i + 1;
            
            // Create detail object for this link
            const detail = {
                link: link,
                status: 'processing',
                timestamp: new Date().toISOString(),
                groupInfo: {}
            };
            
            try {
                // Extract invite code
                let inviteCode = link;
                if (link.includes('chat.whatsapp.com/')) {
                    inviteCode = link.split('chat.whatsapp.com/')[1].split('?')[0].split('/')[0].trim();
                }

                if (!inviteCode) {
                    throw new Error('Invalid link format');
                }

                // Get invite info first (if possible)
                let inviteInfo = null;
                try {
                    inviteInfo = await sock.groupGetInviteInfo(inviteCode);
                    detail.groupInfo = {
                        name: inviteInfo.subject || 'Unknown',
                        description: inviteInfo.desc || 'No description',
                        members: inviteInfo.size || 0,
                        creator: inviteInfo.creator || 'Unknown',
                        creation: inviteInfo.creation || 'Unknown',
                        inviteCode: inviteCode,
                        link: link
                    };
                } catch (e) {
                    detail.groupInfo = {
                        inviteCode: inviteCode,
                        link: link
                    };
                }

                // Try to join
                let groupJid;
                try {
                    groupJid = await sock.groupAcceptInvite(inviteCode);
                } catch (joinError) {
                    if (joinError.message?.includes('already-exists') || joinError.data === 304) {
                        detail.status = 'already_in';
                        detail.message = 'Bot already in group';
                        
                        // Try to get full metadata if already in
                        try {
                            const groups = await sock.groupFetchAllParticipating();
                            const existingGroup = Object.entries(groups).find(([jid, g]) => 
                                g.inviteCode === inviteCode || g.subject === detail.groupInfo.name
                            );
                            if (existingGroup) {
                                const [jid, metadata] = existingGroup;
                                detail.groupInfo = {
                                    ...detail.groupInfo,
                                    jid: jid,
                                    name: metadata.subject || 'Unknown',
                                    description: metadata.desc || 'No description',
                                    members: metadata.participants?.length || 0,
                                    announce: metadata.announce ? 'Yes (Only admins can message)' : 'No (Everyone can message)',
                                    restrict: metadata.restrict ? 'Yes (Only admins can edit)' : 'No (Everyone can edit)',
                                    creator: metadata.owner || 'Unknown',
                                    creation: metadata.creation ? new Date(metadata.creation * 1000).toLocaleString() : 'Unknown',
                                    inviteCode: metadata.inviteCode || inviteCode,
                                    link: link
                                };
                            }
                        } catch (e) {}
                        
                        results.alreadyIn++;
                        results.details.push(detail);
                        
                        // Send detailed update
                        await sock.sendMessage(chatId, { 
                            text: `━━━━━━━━━━━━━━━━━━\n` +
                                  `[${linkNumber}/${results.total}] ⏭️ *ALREADY IN GROUP*\n` +
                                  `━━━━━━━━━━━━━━━━━━\n` +
                                  `📌 *Name:* ${detail.groupInfo.name || 'Unknown'}\n` +
                                  `👥 *Members:* ${detail.groupInfo.members || 0}\n` +
                                  `🔗 *Link:* ${link}\n` +
                                  `📝 *Description:* ${(detail.groupInfo.description || 'No description').substring(0, 100)}${detail.groupInfo.description?.length > 100 ? '...' : ''}\n` +
                                  `🔒 *Restrict:* ${detail.groupInfo.restrict || 'Unknown'}\n` +
                                  `🔇 *Announce:* ${detail.groupInfo.announce || 'Unknown'}\n` +
                                  `🆔 *JID:* ${detail.groupInfo.jid || 'Unknown'}\n` +
                                  `━━━━━━━━━━━━━━━━━━`
                        });
                        continue;
                    }
                    
                    if (joinError.message?.includes('conflict') || joinError.data === 409) {
                        detail.status = 'request_sent';
                        detail.message = 'Join request sent (needs approval)';
                        
                        results.requestSent++;
                        results.details.push(detail);
                        
                        await sock.sendMessage(chatId, { 
                            text: `━━━━━━━━━━━━━━━━━━\n` +
                                  `[${linkNumber}/${results.total}] ⏳ *REQUEST SENT*\n` +
                                  `━━━━━━━━━━━━━━━━━━\n` +
                                  `📌 *Name:* ${detail.groupInfo.name || 'Unknown'}\n` +
                                  `👥 *Members:* ${detail.groupInfo.members || 0}\n` +
                                  `🔗 *Link:* ${link}\n` +
                                  `📝 *Description:* ${(detail.groupInfo.description || 'No description').substring(0, 100)}${detail.groupInfo.description?.length > 100 ? '...' : ''}\n` +
                                  `⏰ *Needs admin approval*\n` +
                                  `━━━━━━━━━━━━━━━━━━`
                        });
                        continue;
                    }
                    
                    throw joinError;
                }

                if (groupJid) {
                    // Successfully joined - get full metadata
                    await new Promise(resolve => setTimeout(resolve, 2000));
                    
                    try {
                        const metadata = await sock.groupMetadata(groupJid);
                        
                        detail.status = 'success';
                        detail.jid = groupJid;
                        detail.groupInfo = {
                            jid: groupJid,
                            name: metadata.subject || 'Unknown',
                            description: metadata.desc || 'No description',
                            members: metadata.participants?.length || 0,
                            announce: metadata.announce ? 'Yes (Only admins can message)' : 'No (Everyone can message)',
                            restrict: metadata.restrict ? 'Yes (Only admins can edit)' : 'No (Everyone can edit)',
                            creator: metadata.owner || 'Unknown',
                            creation: metadata.creation ? new Date(metadata.creation * 1000).toLocaleString() : 'Unknown',
                            inviteCode: inviteCode,
                            link: link,
                            participants: metadata.participants?.map(p => ({
                                id: p.id,
                                admin: p.admin || 'none'
                            })) || []
                        };
                        
                        // Check if bot is admin
                        const botId = sock.user.id.split(':')[0] + '@s.whatsapp.net';
                        const botParticipant = metadata.participants?.find(p => p.id === botId);
                        detail.groupInfo.botAdmin = botParticipant?.admin ? 'Yes' : 'No';
                        
                        results.successful++;
                        results.details.push(detail);
                        
                        // Send detailed success message
                        await sock.sendMessage(chatId, { 
                            text: `━━━━━━━━━━━━━━━━━━\n` +
                                  `[${linkNumber}/${results.total}] ✅ *SUCCESSFULLY JOINED*\n` +
                                  `━━━━━━━━━━━━━━━━━━\n` +
                                  `📌 *Name:* ${detail.groupInfo.name}\n` +
                                  `👥 *Members:* ${detail.groupInfo.members}\n` +
                                  `🔗 *Link:* ${link}\n` +
                                  `📝 *Description:* ${detail.groupInfo.description.substring(0, 150)}${detail.groupInfo.description.length > 150 ? '...' : ''}\n` +
                                  `🔒 *Restrict:* ${detail.groupInfo.restrict}\n` +
                                  `🔇 *Announce:* ${detail.groupInfo.announce}\n` +
                                  `🤖 *Bot Admin:* ${detail.groupInfo.botAdmin}\n` +
                                  `👑 *Creator:* ${detail.groupInfo.creator.split('@')[0]}\n` +
                                  `📅 *Created:* ${detail.groupInfo.creation}\n` +
                                  `🆔 *JID:* ${groupJid}\n` +
                                  `━━━━━━━━━━━━━━━━━━`
                        });
                        
                    } catch (metaError) {
                        // Use invite info if metadata fails
                        detail.status = 'success';
                        detail.jid = groupJid;
                        detail.groupInfo = {
                            ...detail.groupInfo,
                            jid: groupJid,
                            name: detail.groupInfo.name || 'Unknown',
                            members: detail.groupInfo.members || 0
                        };
                        
                        results.successful++;
                        results.details.push(detail);
                        
                        await sock.sendMessage(chatId, { 
                            text: `━━━━━━━━━━━━━━━━━━\n` +
                                  `[${linkNumber}/${results.total}] ✅ *JOINED (Limited Info)*\n` +
                                  `━━━━━━━━━━━━━━━━━━\n` +
                                  `📌 *Name:* ${detail.groupInfo.name}\n` +
                                  `👥 *Members:* ${detail.groupInfo.members}\n` +
                                  `🔗 *Link:* ${link}\n` +
                                  `🆔 *JID:* ${groupJid}\n` +
                                  `━━━━━━━━━━━━━━━━━━`
                        });
                    }
                }
                
            } catch (error) {
                // Failed to join
                detail.status = 'failed';
                detail.error = error.message;
                results.failed++;
                results.details.push(detail);
                
                await sock.sendMessage(chatId, { 
                    text: `━━━━━━━━━━━━━━━━━━\n` +
                          `[${linkNumber}/${results.total}] ❌ *FAILED*\n` +
                          `━━━━━━━━━━━━━━━━━━\n` +
                          `🔗 *Link:* ${link.substring(0, 50)}...\n` +
                          `⚠️ *Reason:* ${error.message.substring(0, 100)}\n` +
                          `━━━━━━━━━━━━━━━━━━`
                });
            }

            // Wait 5 seconds between joins (except after last)
            if (i < links.length - 1) {
                await new Promise(resolve => setTimeout(resolve, 5000));
            }
        }

        // Generate comprehensive report
        const timeTaken = ((Date.now() - startTime) / 1000).toFixed(1);
        
        let report = `📊 *BULK JOIN FINAL REPORT*\n`;
        report += `━━━━━━━━━━━━━━━━━━\n`;
        report += `⏱️ *Time:* ${timeTaken}s\n`;
        report += `📁 *Total Links:* ${results.total}\n`;
        report += `✅ *Joined:* ${results.successful}\n`;
        report += `⏭️ *Already In:* ${results.alreadyIn}\n`;
        report += `⏳ *Requests Sent:* ${results.requestSent}\n`;
        report += `❌ *Failed:* ${results.failed}\n`;
        report += `━━━━━━━━━━━━━━━━━━\n\n`;

        // Successfully joined groups summary
        if (results.successful > 0) {
            report += `*✅ SUCCESSFULLY JOINED (${results.successful}):*\n`;
            report += `━━━━━━━━━━━━━━━━━━\n`;
            results.details
                .filter(d => d.status === 'success')
                .forEach((d, idx) => {
                    report += `\n${idx + 1}. *${d.groupInfo.name || 'Unknown'}*\n`;
                    report += `   👥 Members: ${d.groupInfo.members || 0}\n`;
                    report += `   🔒 Restrict: ${d.groupInfo.restrict || 'Unknown'}\n`;
                    report += `   🔇 Announce: ${d.groupInfo.announce || 'Unknown'}\n`;
                    report += `   🤖 Bot Admin: ${d.groupInfo.botAdmin || 'No'}\n`;
                    report += `   🆔 JID: ${d.jid || 'Unknown'}\n`;
                    report += `   🔗 Link: ${d.link}\n`;
                });
            report += `━━━━━━━━━━━━━━━━━━\n\n`;
        }

        // Groups needing approval
        if (results.requestSent > 0) {
            report += `*⏳ AWAITING APPROVAL (${results.requestSent}):*\n`;
            report += `━━━━━━━━━━━━━━━━━━\n`;
            results.details
                .filter(d => d.status === 'request_sent')
                .forEach((d, idx) => {
                    report += `\n${idx + 1}. *${d.groupInfo.name || 'Unknown'}*\n`;
                    report += `   👥 Members: ${d.groupInfo.members || 0}\n`;
                    report += `   🔗 Link: ${d.link}\n`;
                });
            report += `━━━━━━━━━━━━━━━━━━\n\n`;
        }

        // Already in groups
        if (results.alreadyIn > 0) {
            report += `*⏭️ ALREADY MEMBER (${results.alreadyIn}):*\n`;
            report += `━━━━━━━━━━━━━━━━━━\n`;
            results.details
                .filter(d => d.status === 'already_in')
                .forEach((d, idx) => {
                    report += `\n${idx + 1}. *${d.groupInfo.name || 'Unknown'}*\n`;
                    report += `   👥 Members: ${d.groupInfo.members || 0}\n`;
                    report += `   🔗 Link: ${d.link}\n`;
                });
            report += `━━━━━━━━━━━━━━━━━━\n\n`;
        }

        // Failed joins
        if (results.failed > 0) {
            report += `*❌ FAILED (${results.failed}):*\n`;
            report += `━━━━━━━━━━━━━━━━━━\n`;
            results.details
                .filter(d => d.status === 'failed')
                .forEach((d, idx) => {
                    report += `\n${idx + 1}. *Link:* ${d.link.substring(0, 50)}...\n`;
                    report += `   ⚠️ Error: ${d.error}\n`;
                });
            report += `━━━━━━━━━━━━━━━━━━\n`;
        }

        // Send final report
        await sock.sendMessage(chatId, { text: report });

        // Save full results to JSON file
        const resultFile = path.join(process.cwd(), 'temp', `bulkjoin_${Date.now()}.json`);
        fs.writeFileSync(resultFile, JSON.stringify(results, null, 2));
        
        // Send the result file
        if (fs.existsSync(resultFile)) {
            await sock.sendMessage(chatId, {
                document: fs.readFileSync(resultFile),
                fileName: `bulkjoin_${Date.now()}.json`,
                mimetype: 'application/json',
                caption: '📄 Complete bulk join report with full group details'
            });
        }

    } catch (error) {
        console.error('Bulk join error:', error);
        await sock.sendMessage(chatId, { 
            text: '❌ Failed to process bulk join command.\nError: ' + error.message 
        });
    }
}

module.exports = bulkjoinCommand;
